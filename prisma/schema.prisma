generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ═══════════════════════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════════════════════

// They switch contexts inside the app — no re-login needed.

// null = manager only (role assigned by owner via invitation)
// non-null = self-selected owner — can be edited from profile
enum OwnerType {
  BOAT      // owns boats only
  COMPANY   // owns a company only
  BOTH      // owns boats + a company
}

model User {
  id        String     @id @default(uuid())
  phone     String     @unique
  name      String?
  ownerType OwnerType?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  ownedBoats         Boat[]              @relation("BoatOwner")
  ownedCompanies     Company[]           @relation("CompanyOwner")
  boatAssignments    BoatAssignment[]
  companyMemberships CompanyMembership[]
  otps               OTP[]
  sessions           Session[]
  sentInvitations    Invitation[]

  @@map("users")
}

model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  userId    String?
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("otps")
}

// ═══════════════════════════════════════════════════════════════════
// COMPANY
// ═══════════════════════════════════════════════════════════════════

// A fishing company. Owned by one user.
// Can have multiple managers and multiple boats.

model Company {
  id           String   @id @default(uuid())
  name         String
  nameGujarati String?
  phone        String?
  address      String?
  gstNumber    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId      String
  owner        User     @relation("CompanyOwner", fields: [ownerId], references: [id])

  // Managers hired for this company
  memberships  CompanyMembership[]

  // Boats registered under this company
  // (includes owner's boats + external boats that come here)
  registeredBoats RegisteredBoat[]

  // Sessions (tali events) at this company
  sessions     Session[]

  // Company-level expenses
  expenses     CompanyExpense[]

  // Invitations sent for this company
  invitations  Invitation[]

  @@map("companies")
}

// Links a manager (User) to a Company.
// Owner controls permissions per manager.

model CompanyMembership {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions CompanyPermission[]

  // One membership per person per company
  @@unique([companyId, userId])
  @@map("company_memberships")
}

// Every permission the owner can toggle on/off per company manager

enum CompanyPermissionType {
  // Tali operations
  CREATE_TALI              // start a tali session
  VIEW_TALI                // see tali list and weight data
  FILL_FISH_PRICE          // enter price per kg — OFF by default (owner sensitive)

  // Bill operations
  VIEW_BILL                // see generated bills
  CREATE_BILL              // generate a bill — OFF by default
  SEND_BILL                // send bill via WhatsApp

  // Expense operations
  ADD_COMPANY_EXPENSE      // add company-level costs
  VIEW_COMPANY_EXPENSE     // see company expense records

  // Employee operations
  VIEW_EMPLOYEE_RECORDS    // see staff financial records
  MANAGE_EMPLOYEES         // add or edit staff

  // Reports — owner private by default
  VIEW_FINANCIAL_REPORT    // profit/loss, business insight — OFF by default

  // Team management
  VIEW_MEMBERS             // see who else is a manager
}

model CompanyPermission {
  id           String                @id @default(uuid())
  membershipId String
  permission   CompanyPermissionType
  createdAt    DateTime              @default(now())

  membership   CompanyMembership     @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, permission])
  @@map("company_permissions")
}

// ═══════════════════════════════════════════════════════════════════
// BOAT
// ═══════════════════════════════════════════════════════════════════

// A boat owned by a User.
// Can be linked to a company (optional).
// Kumar's personal boat is NOT linked to Suresh's company.

model Boat {
  id                 String   @id @default(uuid())
  name               String
  nameGujarati       String?
  registrationNumber String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // The person who owns this boat
  ownerId            String
  owner              User     @relation("BoatOwner", fields: [ownerId], references: [id])

  // Managers assigned to this boat by the owner
  assignments        BoatAssignment[]

  // Expenses recorded for this boat
  expenses           BoatExpense[]

  // Sessions where this boat's fish was weighed
  sessions           Session[]

  // This boat registered at which companies
  // (Suresh's boat can be registered at his own company
  //  AND at another company if needed)
  registeredAt       RegisteredBoat[]

  @@map("boats")
}

// Links a manager (User) to a Boat.
// Damodar assigns Bhuro to boats 1,3,5 — Bhuro sees only those.
// Manager opens app, sees assigned boats, picks the arrived one.

model BoatAssignment {
  id        String   @id @default(uuid())
  boatId    String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boat        Boat            @relation(fields: [boatId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions BoatPermission[]

  // One assignment per person per boat
  @@unique([boatId, userId])
  @@map("boat_assignments")
}

// Every permission the owner can toggle on/off per boat manager

enum BoatPermissionType {
  // Expense operations
  ADD_BOAT_EXPENSE         // add diesel, maintenance, crew kharchi
  VIEW_BOAT_EXPENSE        // see expense records

  // Tali (when manager does both boat + company work like Maniyo)
  CREATE_TALI
  VIEW_TALI
  FILL_FISH_PRICE          // OFF by default

  // Bill
  VIEW_BILL                // OFF by default
  CREATE_BILL              // OFF by default

  // Reports — owner private
  VIEW_FINANCIAL_REPORT    // OFF by default
}

model BoatPermission {
  id           String           @id @default(uuid())
  assignmentId String
  permission   BoatPermissionType
  createdAt    DateTime         @default(now())

  assignment   BoatAssignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, permission])
  @@map("boat_permissions")
}

// ═══════════════════════════════════════════════════════════════════
// REGISTERED BOAT
// Pre-registered boats that come to a company.
// Can be the owner's own boat OR an external boat (Ramesh's boat).
// Shrutikant cannot add unknown boats — Suresh pre-registers them all.
// ═══════════════════════════════════════════════════════════════════

model RegisteredBoat {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  nameGujarati String?
  ownerName    String?  // Ramesh — even if not an app user
  ownerPhone   String?  // for WhatsApp bill delivery
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // If the boat owner is an app user — link them
  // so bill is delivered in-app too
  appBoatId    String?  // links to Boat.id if owner uses the app
  appBoat      Boat?    @relation(fields: [appBoatId], references: [id])

  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Sessions where this registered boat's fish was weighed
  sessions     Session[]

  @@unique([companyId, name])
  @@map("registered_boats")
}

// ═══════════════════════════════════════════════════════════════════
// EXPENSES
// ═══════════════════════════════════════════════════════════════════

// Boat expenses — added by boat manager or owner
// Three categories: DIESEL, MAINTENANCE, CREW_KHARCHI

enum BoatExpenseCategory {
  DIESEL
  MAINTENANCE   // custom description required
  CREW_KHARCHI
}

model BoatExpense {
  id          String              @id @default(uuid())
  boatId      String
  category    BoatExpenseCategory
  amount      Float

  // For MAINTENANCE — custom description
  // eg: "Refreshment drink for crew"
  // eg: "Engine repair"
  description String?

  tripDate    DateTime            @default(now())
  addedById   String?             // which manager added this
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  boat        Boat                @relation(fields: [boatId], references: [id], onDelete: Cascade)

  @@map("boat_expenses")
}

// Company expenses — added by company manager or owner

enum CompanyExpenseCategory {
  MAINTENANCE   // custom description required
  SALARY
  UTILITIES
  OTHER         // custom description required
}

model CompanyExpense {
  id          String                 @id @default(uuid())
  companyId   String
  category    CompanyExpenseCategory
  amount      Float
  description String?                // always required for MAINTENANCE and OTHER
  expenseDate DateTime               @default(now())
  addedById   String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_expenses")
}

// ═══════════════════════════════════════════════════════════════════
// SESSION (TALI)
// One fish unloading event at a company.
// Created by Shrutikant on behalf of Suresh's company.
// ═══════════════════════════════════════════════════════════════════

model Session {
  id               String        @id @default(uuid())

  // Which company is receiving the fish
  companyId        String

  // Which boat brought the fish
  // registeredBoatId — always from the pre-registered list
  registeredBoatId String

  // Which user created this tali (Shrutikant)
  createdById      String

  // Optional — if it's also one of the owner's own boats
  boatId           String?

  status           SessionStatus @default(ACTIVE)
  startTime        DateTime      @default(now())
  endTime          DateTime?
  notes            String?

  // Offline sync support
  clientId         String?       @unique
  syncedAt         DateTime?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  company          Company        @relation(fields: [companyId], references: [id])
  registeredBoat   RegisteredBoat @relation(fields: [registeredBoatId], references: [id])
  createdBy        User           @relation(fields: [createdById], references: [id])
  boat             Boat?          @relation(fields: [boatId], references: [id])
  fishEntries      FishEntry[]
  bill             Bill?

  @@map("sessions")
}

enum SessionStatus {
  ACTIVE        // tali in progress
  PENDING_PRICE // weights done, waiting for owner to fill price
  BILLED        // bill generated
  CANCELLED
}

// ═══════════════════════════════════════════════════════════════════
// FISH ENTRY
// One fish type within a session.
// Weight visible to manager. Price filled by owner (or permitted manager).
// ═══════════════════════════════════════════════════════════════════

model FishEntry {
  id               String   @id @default(uuid())
  sessionId        String
  fishId           String   // matches FISH_CATEGORIES id from frontend
  fishName         String
  fishNameGujarati String?
  bucketWeight     Float
  totalKg          Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  billItem         BillItem?

  @@map("fish_entries")
}

// ═══════════════════════════════════════════════════════════════════
// BILL
// Generated after owner fills prices.
// Sent to registered boat owner via WhatsApp.
// If boat owner is app user — stored in their profile too.
// ═══════════════════════════════════════════════════════════════════

model Bill {
  id                String     @id @default(uuid())
  sessionId         String     @unique
  billNumber        String     @unique // eg: BILL-20260302-X7K2
  subtotal          Float
  sellingCharge     Float
  sellingChargeRate Float      @default(0.06)
  finalTotal        Float
  status            BillStatus @default(DRAFT)

  // Who filled the prices (owner or permitted manager)
  priceFilledById   String?

  // Bill delivery
  sentViaWhatsApp   Boolean    @default(false)
  whatsappSentAt    DateTime?

  generatedAt       DateTime   @default(now())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  session           Session    @relation(fields: [sessionId], references: [id])
  items             BillItem[]

  @@map("bills")
}

enum BillStatus {
  DRAFT       // prices filled, not confirmed
  CONFIRMED   // locked — no more edits
  SENT        // delivered to boat owner
  CANCELLED
}

model BillItem {
  id               String    @id @default(uuid())
  billId           String
  fishEntryId      String    @unique
  fishName         String
  fishNameGujarati String?
  totalKg          Float
  pricePerKg       Float
  totalAmount      Float
  createdAt        DateTime  @default(now())

  bill             Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  fishEntry        FishEntry @relation(fields: [fishEntryId], references: [id])

  @@map("bill_items")
}

// ═══════════════════════════════════════════════════════════════════
// INVITATION
// Owner sends invite to manager via email.
// Manager accepts → membership created automatically.
// Owner can revoke anytime.
// ═══════════════════════════════════════════════════════════════════

model Invitation {
  id           String           @id @default(uuid())
  code         String           @unique  // eg: SURESH-K7X2 — sent to manager
  email        String           // manager's email
  entityType   EntityType
  companyId    String?          // if inviting to a company
  boatId       String?          // if inviting to a boat
  invitedById  String           // the owner
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime         // 48 hours
  acceptedAt   DateTime?
  createdAt    DateTime         @default(now())

  company      Company?         @relation(fields: [companyId], references: [id])
  invitedBy    User             @relation(fields: [invitedById], references: [id])

  // Default permissions to apply when manager accepts
  // Stored as JSON array — eg: ["CREATE_TALI", "VIEW_TALI"]
  defaultPermissions Json       @default("[]")

  @@map("invitations")
}

enum EntityType {
  BOAT
  COMPANY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}